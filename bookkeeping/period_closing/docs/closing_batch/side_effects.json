{
  "create": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "in_review"
      }
    }
  ],
  "review": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "in_review"
      }
    }
  ],
  "approve": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "approved"
      }
    },
    {
      "type": "create_record",
      "target_doc": "adjustment_entry",
      "values": {
        "title": {
          "$template": "Adjustment Entry for {title|reference_no|id}"
        },
        "reference_no": {
          "$template": "ADJUSTMENT_ENTRY-{reference_no|id}"
        }
      }
    }
  ],
  "close": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "closed"
      }
    }
  ],
  "archive": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "archived"
      }
    }
  ]
}
