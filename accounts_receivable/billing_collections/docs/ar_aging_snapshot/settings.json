{
  "display": {
    "title_template": "{title}",
    "subtitle_template": "{reference_no}",
    "list_columns": [
      "title",
      "reference_no",
      "posting_date",
      "workflow_state"
    ],
    "default_filters": [],
    "quick_entry": false
  },
  "related_docs": [
    {
      "doc_id": "customer_invoice",
      "relation_type": "related",
      "show_in_related_panel": true
    },
    {
      "doc_id": "customer_account",
      "relation_type": "related",
      "show_in_related_panel": true
    }
  ],
  "lookup_rules": [
    {
      "field_id": "customer",
      "doc_id": "customer_account",
      "lookup_mode": "single",
      "purpose": "party_reference"
    }
  ],
  "fetch_rules": [
    {
      "field_id": "customer",
      "source_doc_id": "customer_account",
      "fetch_profile": "customer_profile",
      "fetch_fields": [
        "title",
        "reference_no",
        "customer_code",
        "email",
        "phone",
        "contact_email",
        "contact_phone"
      ],
      "purpose": "party_reference"
    }
  ],
  "reference_map": {
    "primary_reference_field": "reference_no",
    "reference_labels": []
  },
  "relation_rules": {
    "parent_doc": null,
    "child_docs": [],
    "show_related_panel": true
  },
  "borrowed_fields": [
    {
      "description": "customer identity from customer_account"
    },
    {
      "description": "due balances from customer_invoice"
    }
  ],
  "ui_panels": {
    "show_activity_log": true,
    "show_comments": true,
    "show_assignments": true,
    "show_related_docs": true
  },
  "integration": {
    "external_refs": [],
    "sync_rules": []
  },
  "runtime_hints": {
    "doc_key": "ar_aging_snapshot",
    "supports_related_lookup": true,
    "supports_fetch_rules": true
  }
}
