      "reference_no",
      "transaction_date",
      "party",
      "total_amount",
      "workflow_state"
    ],
    "default_filters": [],
    "quick_entry": false
  },
  "related_docs": [
    {
      "doc_id": "customer_account",
      "relation_type": "related",
