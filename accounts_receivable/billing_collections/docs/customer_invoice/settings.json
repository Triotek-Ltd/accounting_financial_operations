      "show_in_related_panel": true
    }
  ],
  "lookup_rules": [
    {
      "field_id": "customer",
      "doc_id": "customer_account",
      "lookup_mode": "single",
      "purpose": "party_reference"
    },
    {
      "field_id": "related_receipt_record",
      "doc_id": "receipt_record",
