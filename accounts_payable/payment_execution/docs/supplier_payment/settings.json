{
  "display": {
    "title_template": "{title}",
    "subtitle_template": "{reference_no}",
    "list_columns": [
      "title",
      "reference_no",
      "transaction_date",
      "party",
      "total_amount",
      "workflow_state"
    ],
    "default_filters": [],
    "quick_entry": false
  },
  "related_docs": [
    {
      "doc_id": "supplier_invoice",
      "relation_type": "related",
      "show_in_related_panel": true
    },
    {
      "doc_id": "payment_request",
      "relation_type": "related",
      "show_in_related_panel": true
    },
    {
      "doc_id": "cash_account",
      "relation_type": "related",
      "show_in_related_panel": true
    },
    {
      "doc_id": "journal_entry",
      "relation_type": "related",
      "show_in_related_panel": true
    }
  ],
  "lookup_rules": [
    {
      "field_id": "supplier",
      "doc_id": "supplier_invoice",
      "lookup_mode": "single",
      "purpose": "party_reference"
    },
    {
      "field_id": "settled_invoices",
      "doc_id": "supplier_invoice",
      "lookup_mode": "multiple",
      "purpose": "relation_collection"
    },
    {
      "field_id": "related_payment_request",
      "doc_id": "payment_request",
      "lookup_mode": "multiple",
      "purpose": "relation_collection"
    },
    {
      "field_id": "related_cash_account",
      "doc_id": "cash_account",
      "lookup_mode": "multiple",
      "purpose": "relation_collection"
    },
    {
      "field_id": "related_journal_entry",
      "doc_id": "journal_entry",
      "lookup_mode": "multiple",
      "purpose": "relation_collection"
    }
  ],
  "fetch_rules": [
    {
      "field_id": "supplier",
      "source_doc_id": "supplier_invoice",
      "fetch_profile": "supplier_profile",
      "fetch_fields": [
        "title",
        "reference_no",
        "supplier_code",
        "email",
        "phone",
        "contact_email",
        "contact_phone"
      ],
      "purpose": "party_reference"
    }
  ],
  "reference_map": {
    "primary_reference_field": "reference_no",
    "reference_labels": []
  },
  "relation_rules": {
    "parent_doc": null,
    "child_docs": [
      "supplier_invoice",
      "payment_request",
      "cash_account",
      "journal_entry"
    ],
    "show_related_panel": true
  },
  "borrowed_fields": [
    {
      "description": "supplier"
    },
    {
      "description": "outstanding amount from supplier_invoice"
    },
    {
      "description": "execution intent from payment_request"
    }
  ],
  "ui_panels": {
    "show_activity_log": true,
    "show_comments": true,
    "show_assignments": true,
    "show_related_docs": true
  },
  "integration": {
    "external_refs": [],
    "sync_rules": []
  },
  "runtime_hints": {
    "doc_key": "supplier_payment",
    "supports_related_lookup": true,
    "supports_fetch_rules": true,
    "workflow_hints": {
      "business_objective": "receive supplier invoices, verify them against procurement evidence, approve them, pay them, and keep the payable ledger current",
      "actors": [
        "AP clerk",
        "reviewer",
        "approver",
        "treasury or finance officer"
      ],
      "start_condition": "a supplier invoice is received",
      "ordered_steps": [
        "Execute supplier payment.",
        "Reconcile payment against invoice balances.",
        "Archive invoice and payment evidence."
      ],
      "primary_actions": [
        "create",
        "review",
        "approve",
        "post",
        "reconcile",
        "reverse",
        "archive"
      ],
      "primary_transitions": [
        "supplier_payment: draft -> approved -> posted",
        "supplier_payment: posted -> reconciled"
      ],
      "downstream_effects": [
        "updates AP aging, cash management, bookkeeping, and supplier history"
      ],
      "action_actors": {
        "create": [
          "AP clerk"
        ],
        "review": [
          "reviewer"
        ],
        "approve": [
          "approver"
        ],
        "post": [
          "treasury or finance officer"
        ],
        "reconcile": [
          "treasury or finance officer"
        ],
        "reverse": [
          "approver"
        ],
        "archive": [
          "AP clerk"
        ]
      }
    },
    "action_side_effects_file": "side_effects.json"
  }
}
